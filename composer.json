{
  "name":"veasin/ff",
  "description":"A minimalist, functional PHP framework. Focus on declarative config, tail-call optimization, and clear domain modeling.",
  "type":"library",
  "license":"LGPL-3.0-or-later",
  "authors":[
    {
      "name":"V",
      "email":"vea.git@gmail.com"
    }
  ],
  "require":{
    "php":"^8.4",
    "ext-pdo":"*",
    "ext-json":"*",
	"ext-fileinfo":"*"
  },
  "require-dev":{
    "veasin/ff-sql":">=0.1.0"
  },
  "autoload":{
    "psr-4":{
      "ff\\":"src/"
    },
    "files":[
      "src/hook.php",
      "src/test.php",
      "src/env.php",
      "src/container.php",
      "src/filter.php",
      "src/args.php",
      "src/from.php",
      "src/input.php",
      "src/output/http.php",
      "src/output/type/json.php",
	  "src/output/type/file.php",
      "src/output/type/view.php",
      "src/output.php",
      "src/i18n.php",
      "src/key.php",
      "src/hump.php",
      "src/middleware.php",
      "src/route.php",
      "src/db.php",
      "src/cache.php",
      "src/cache/apcu.php",
      "src/cache/redis.php",
      "src/safe.php",
      "src/http.php",
      "src/http/curl.php",
      "src/http/stream.php",
      "src/log.php",
      "src/middleware/prefab/auth/basic.php",
      "src/middleware/prefab/auth/token.php",
      "src/middleware/prefab/auth/jwt.php",
      "src/middleware/prefab/auth/apikey.php",
      "src/middleware/prefab/cors.php",
      "src/middleware/prefab/csrf.php",
      "src/middleware/prefab/error.php",
      "src/middleware/prefab/gzip.php",
      "src/middleware/prefab/json.php",
      "src/middleware/prefab/log.php",
      "src/middleware/prefab/rate.php",
      "src/middleware/prefab/serve.php",
      "src/route/rest.php"
    ]
  }
}
