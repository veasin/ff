{
  "name":"veasin/nx-tiny",
  "description":"A minimalist, functional PHP framework. Focus on declarative config, tail-call optimization, and clear domain modeling.",
  "type":"library",
  "license":"LGPL-3.0-or-later",
  "authors":[
    {
      "name":"V",
      "email":"vea.git@gmail.com"
    }
  ],
  "require":{
    "php":"^8.4",
    "ext-pdo":"*",
    "ext-json":"*",
	"ext-fileinfo":"*"
  },
  "require-dev":{
    "veasin/nx-sql":"*"
  },
  "autoload":{
    "psr-4":{
      "nx\\":"src/"
    },
    "files":[
      "dist/nx.php"
    ]
  },
  "scripts": {
	"build":"php tools/build.php",
	"build-test":"php tools/build-test.php"
  }
}
