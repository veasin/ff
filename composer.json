{
  "name":"veasin/ff",
  "description":"A minimalist, functional PHP framework. Focus on declarative config, tail-call optimization, and clear domain modeling.",
  "type":"library",
  "license":"LGPL-3.0-or-later",
  "authors":[
    {
      "name":"V",
      "email":"vea.git@gmail.com"
    }
  ],
  "require":{
    "php":"^8.4",
    "ext-pdo":"*",
    "ext-json":"*",
	"ext-fileinfo":"*"
  },
  "require-dev":{
    "veasin/ff-sql":">=0.1.0"
  },
  "suggest":{
    "veasin/ff-franken":"FrankenPHP worker mode adapter",
    "veasin/ff-llm":"Unified LLM chat interface with multi-provider switching and tool calling",
    "veasin/ff-log-ws":"WebSocket real-time log transport",
    "veasin/ff-sql":"SQL query builder, DDL generation, and database migration",
    "veasin/ff-redis":"Redis connection pool, queue driver, and cache driver",
    "veasin/ff-web":"Web middleware collection — CORS, CSRF, gzip, JSON, logging, rate limiter, static file serving, and auth",
    "veasin/ff-xdebug":"Xdebug trace viewer with formatted timeline table"
  },
  "autoload":{
    "psr-4":{
      "ff\\":"src/"
    },
    "files":[
      "src/hook.php",
      "src/test.php",
      "src/env.php",
      "src/container.php",
      "src/ext.php",
      "src/filter.php",
      "src/filter/rules.php",
      "src/filter/check.php",
      "src/args.php",
      "src/from.php",
      "src/from/header.php",
      "src/from/body.php",
      "src/input.php",
      "src/output/cli.php",
      "src/output/http.php",
      "src/output/type/json.php",
	  "src/output/type/file.php",
      "src/output/type/view.php",
      "src/output.php",
      "src/i18n.php",
      "src/key.php",
      "src/name.php",
      "src/hump.php",
      "src/middleware.php",
      "src/route.php",
      "src/db.php",
      "src/cache.php",
      "src/cache/apcu.php",
      "src/safe.php",
      "src/http.php",
      "src/http/curl.php",
      "src/http/stream.php",
      "src/log.php",
      "src/log/error.php",
      "src/route/rest.php",
      "src/queue.php",
      "src/queue/db.php",
      "src/resource/pdo.php",
      "bootstrap.php"
    ]
  }
}
